{
    "name": "cakephp/app",
    "description": "CakePHP skeleton app",
    "license": "MIT",
    "type": "project",
    "homepage": "https://cakephp.org",
    "require": {
        "php": ">=8.5",
        "cakephp/authentication": "^4.1.0",
        "cakephp/cakephp": "5.3.4",
        "cakephp/migrations": "^5.1.1",
        "cakephp/plugin-installer": "^2.0.2",
        "ezyang/htmlpurifier": "^4.19",
        "google/apiclient": "^2.19.3",
        "mobiledetect/mobiledetectlib": "^4.8.03"
    },
    "require-dev": {
        "cakephp/bake": "^3.6.3",
        "cakephp/cakephp-codesniffer": "^5.3.0",
        "cakephp/debug_kit": "^5.2.2",
        "josegonzalez/dotenv": "^4.0",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.54",
        "phpunit/phpunit": "^13.1.8"
    },
    "suggest": {
        "cakephp/repl": "Console tools for a REPL interface for CakePHP applications.",
        "dereuromark/cakephp-ide-helper": "After baking your code, this keeps your annotations in sync with the code evolving from there on for maximum IDE and PHPStan/Psalm compatibility.",
        "markstory/asset_compress": "An asset compression plugin which provides file concatenation and a flexible filter system for preprocessing and minification.",
        "phpstan/phpstan": "PHPStan focuses on finding errors in your code without actually running it. It catches whole classes of bugs even before you write tests for the code."
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "cakephp/plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "platform-check": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": "App\\Console\\Installer::postInstall",
        "post-create-project-cmd": "App\\Console\\Installer::postInstall",
        "cs-check": "phpcs --colors -p",
        "cs-fix": "phpcbf --colors -p",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    }
}
